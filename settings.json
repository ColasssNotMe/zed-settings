// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "prettier": {
    "allowed": true,
  },

  "file_types": {
    "HTML": ["svg"],
  },

  "window_decorations": "client",
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_sign_in": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_name": true,
    "show_branch_icon": true,
  },
  "toolbar": {
    "code_actions": true,
    "quick_actions": true,
    "breadcrumbs": true,
  },
  "buffer_font_family": "JetBrains Mono",
  "preferred_line_length": 75,
  "relative_line_numbers": "enabled",
  "show_edit_predictions": false,
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "font_family": ".ZedMono",
  },
  "icon_theme": "Colored Zed Icons Theme Dark",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "enabled_in_text_threads": false,
  },
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "hide_hidden": false,
    "hide_root": false,
    "indent_guides": {
      "show": "always",
    },
    "indent_size": 15.0,
    "auto_fold_dirs": false,
    "dock": "right",
  },
  "soft_wrap": "editor_width",
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
    "profiles": {
      "agent": {
        "name": "Agent",
        "tools": {
          "fetch": true,
          "thinking": true,
          "terminal": false,
          "read_file": true,
          "open": true,
          "now": true,
          "list_directory": true,
          "grep": true,
          "find_path": true,
          "copy_path": true,
          "diagnostics": true,
          "edit_file": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_profile": "ask",
    "dock": "right",
    "model_parameters": [],
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6",
    },
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "Kanagawa Lotus",
    "dark": "Sublime Mariana",
  },
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
  },
}
